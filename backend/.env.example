# Local development — copy to backend/.env (optional; dev settings work without this)

# DJANGO_SETTINGS_MODULE=config.settings.dev
# DJANGO_SECRET_KEY=dev-only-secret

# Use SQLite by default. For local Docker Postgres instead:
# DATABASE_URL=postgresql://labour:labour@localhost:5432/labour

# Do NOT use production Railway vars locally unless you mean to hit Railway DB/API.
