# Copy to .env for local dev. On Railway, set variables in the service dashboard.

# Django
# DJANGO_SECRET_KEY=change-me-in-production
# DJANGO_SETTINGS_MODULE=config.settings.prod   
# ALLOWED_HOSTS=your-api.up.railway.app
# CORS_ALLOWED_ORIGINS=https://labour-management.up.railway.app
# FRONTEND_URL=https://labour-management.up.railway.app
# FRONTEND_URL=https://labour-management.up.railway.app

# ── Railway PostgreSQL (pick ONE approach) ───────────────────────────────

# Option A — recommended: paste the full URL from Railway
#   Postgres service → Connect → DATABASE_URL (or "Postgres connection URL")
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.railway.app:5432/railway

# Option B — individual fields (same values Railway shows under Variables)
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=your-password-from-railway
# DB_HOST=postgres.railway.internal
# DB_PORT=5432

# Railway also injects PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE automatically
# when you link the Postgres plugin to your API service — no .env needed for those.

# Local dev without Postgres uses SQLite. To use local Docker Postgres instead:
# DATABASE_URL=postgresql://labour:labour@localhost:5432/labour
